# ChainedPy Environment Configuration
{% if repository_url -%}
# Repository: {{ repository_url }}
{% endif -%}
# This file contains credentials for accessing remote repositories

{% if repo_type == 'github' -%}
# GitHub Access (for private repositories)
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (for private repos)
GITHUB_TOKEN={{ github_token or "your_github_token_here" }}

{% elif repo_type == 'gitlab' -%}
# GitLab Access (for private repositories)
# Get token from: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: read_repository
GITLAB_TOKEN={{ gitlab_token or "your_gitlab_token_here" }}
GITLAB_PRIVATE_TOKEN={{ gitlab_token or "your_gitlab_token_here" }}

{% elif repo_type == 'ftp' -%}
# FTP Access
FTP_USERNAME=your_ftp_username
FTP_PASSWORD=your_ftp_password

{% elif repo_type == 'sftp' -%}
# SFTP Access
SFTP_USERNAME=your_sftp_username
SFTP_PASSWORD=your_sftp_password

{% else -%}
# GitHub Access (for private repositories)
# Get token from: https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_token_here

# GitLab Access (for private repositories)
# Get token from: https://gitlab.com/-/profile/personal_access_tokens
# GITLAB_TOKEN=your_gitlab_token_here
# GITLAB_PRIVATE_TOKEN=your_gitlab_token_here

# FTP/SFTP Access (if needed)
# FTP_USERNAME=your_ftp_username
# FTP_PASSWORD=your_ftp_password
# SFTP_USERNAME=your_sftp_username
# SFTP_PASSWORD=your_sftp_password

{% endif -%}
# Notes:
# - Public repositories don't require tokens
# - Tokens are only needed for private repositories or to increase rate limits
# - Keep this file secure and don't commit it to version control
